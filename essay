<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Merveilles de l'Égypte</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>

    <header>
        <nav class="navbar">
            <h2 class="logo">Merveilles de l'Égypte</h2>

            <div class="menu">
                <a href="index.html">Accueil</a>
                <a href="oeuvres.html">Œuvres</a>
                <a href="galerie.html">Galerie</a>
                <a href="visite-contact.html">Visite & Contact</a>
            </div>
        </nav>
    </header>

    <main>

        <section class="hero">

            <div class="hero-texte">
                <div class="bulle-titre">
                    <h1>Les merveilles de l'Égypte</h1>
                </div>

                <p class="slogan">
                    Explorez les trésors et les mystères de l'Égypte ancienne.
                </p>

                <p>
                    Découvrez les pyramides, les temples et les trésors de l'Égypte ancienne.
                </p>

                <a href="oeuvres.html" class="bouton">Explorer</a>
            </div>

            <div class="hero-image">
                <img src="assets/images/pyramides.JPG" alt="Pyramides de Gizeh" usemap="#map-egypte">

                <map name="map-egypte">
                    <area shape="rect" coords="110,120,250,300" href="oeuvres.html" alt="Aller à la page Œuvres">
                    <area shape="rect" coords="260,70,470,320" href="galerie.html" alt="Aller à la page Galerie">
                </map>
            </div>

        </section>

        <section class="apercu">

            <h2>Aperçu de l'exposition</h2>

            <article class="bloc">
                <h3>Œuvres</h3>
                <p>Explorez trois lieux emblématiques : les pyramides de Gizeh, le temple de Karnak et la Vallée des Rois.</p>

                <div class="preview">
                    <img src="assets/images/pyramides.JPG" alt="Aperçu œuvres">
                </div>

                <a href="oeuvres.html">Voir plus</a>
            </article>

            <article class="bloc">
                <h3>Galerie</h3>
                <p>Parcourez une collection d'images inspirées de l'histoire, du désert et de l'architecture égyptienne.</p>

                <div class="preview">
                    <img src="assets/images/hieroglyphes.jpg" alt="Aperçu galerie">
                </div>

                <a href="galerie.html">Voir plus</a>
            </article>

            <article class="bloc">
                <h3>Visite & Contact</h3>
                <p>Retrouvez les horaires, les informations pratiques et les moyens de nous contacter.</p>

                <div class="preview">
                    <img src="assets/images/karnak.jpg" alt="Aperçu visite et contact">
                </div>

                <a href="visite-contact.html">Voir plus</a>
            </article>

        </section>

    </main>

    <footer>
        <p>Projet IFT1005 — Exposition virtuelle sur l'Égypte</p>
    </footer>

</body>
</html>















body{
    margin:0;
    font-family:Arial, sans-serif;
    background-color:#0f3d73;
    color:white;
}

.navbar{
    background-color:#14213d;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 40px;
}

.logo{
    margin:0;
    font-size:24px;
}

.menu a{
    color:white;
    text-decoration:none;
    margin-left:20px;
    font-weight:bold;
    position:relative;
    padding-bottom:6px;
    transition:color 0.15s;
}

.menu a::after{
    content:"";
    position:absolute;
    left:0;
    bottom:0;
    width:0;
    height:2px;
    background-color:#f4c27a;
    transition:width 0.15s;
}

.menu a:hover{
    color:#f4c27a;
}

.menu a:hover::after{
    width:100%;
}

.hero{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:30px;
    padding:40px;
    background-color:#1e3a5f;
}

.hero-texte{
    width:45%;
}

.bulle-titre{
    display:inline-block;
    background-color:#e7c28b;
    padding:14px 24px;
    border-radius:20px;
    margin-bottom:18px;
}

.bulle-titre h1{
    margin:0;
    font-size:34px;
    color:white;
    line-height:1.1;
}

.hero-texte p{
    font-size:20px;
    margin-bottom:20px;
}

.bouton{
    display:inline-block;
    background-color:#d4a373;
    color:white;
    text-decoration:none;
    padding:12px 24px;
    border-radius:10px;
    transition:background-color 0.2s, transform 0.2s;
}

.bouton:hover{
    background-color:#e7b988;
    transform:scale(1.05);
}

.hero-image{
    width:55%;
}

.hero-image img{
    width:100%;
    height:auto;
    display:block;
    border-radius:12px;
}

.apercu{
    display:flex;
    gap:20px;
    padding:30px 40px;
    background:#e5e5e5;
    color:#333;
    flex-wrap:wrap;
}

.apercu h2{
    width:100%;
    text-align:center;
    margin:0 0 20px 0;
}

.bloc{
    background-color:#2b4c7e;
    padding:20px;
    border-radius:12px;
    flex:1;
    color:white;
}

.bloc h3{
    margin-top:0;
}

.bloc a{
    color:#f4c27a;
    text-decoration:none;
    font-weight:bold;
}

footer{
    background-color:#14213d;
    text-align:center;
    padding:20px;
}

.page-oeuvres{
    padding:40px;
}

.oeuvre-card{
    display:flex;
    gap:25px;
    background-color:#2b4c7e;
    padding:20px;
    border-radius:14px;
    margin-bottom:30px;
    align-items:flex-start;
}

.oeuvre-card img{
    width:280px;
    height:200px;
    object-fit:cover;
    border-radius:12px;
}

.oeuvre-texte{
    flex:1;
}

.cartel{
    background-color:rgba(255,255,255,0.08);
    padding:15px;
    border-radius:10px;
    margin-top:15px;
}

.titre-page{
    text-align:center;
    margin-top:40px;
    margin-bottom:40px;
}

.galerie{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:20px;
    padding:40px;
}

.galerie img{
    width:100%;
    height:220px;
    object-fit:cover;
    border-radius:10px;
    transition:transform 0.3s;
}

.galerie img:hover{
    transform:scale(1.05);
}

.page-contact{
    padding:40px;
}

.contact-grid{
    display:flex;
    gap:25px;
    margin-bottom:35px;
}

.carte-contact{
    background-color:#2b4c7e;
    padding:25px;
    border-radius:14px;
    flex:1;
}

.carte-contact h2{
    margin-top:0;
}

.carte-contact a{
    color:#f4c27a;
    text-decoration:none;
}

.ressources-card{
    background-color:#2b4c7e;
    padding:25px;
    border-radius:14px;
    margin-bottom:35px;
}

.liens-boutons{
    display:flex;
    gap:15px;
    margin-top:18px;
    flex-wrap:wrap;
}

.liens-boutons a{
    background-color:#d4a373;
    color:white;
    text-decoration:none;
    padding:12px 18px;
    border-radius:10px;
}

.bienvenue-card{
    background-color:#2b4c7e;
    padding:25px;
    border-radius:14px;
}

@media (max-width:768px){
    .hero{
        flex-direction:column;
    }
    
    

    .hero-texte,
    .hero-image{
        width:100%;
    }

    .apercu{
        flex-direction:column;
    }

    .contact-grid{
        flex-direction:column;
    }

    .galerie{
        grid-template-columns:1fr;
    }

    .oeuvre-card{
        flex-direction:column;
    }

    .oeuvre-card img{
        width:100%;
        height:auto;
    }}

    .preview{
display:none;
margin-top:10px;
}

.preview img{
width:100%;
border-radius:8px;
}

.bloc:hover .preview{
display:block;
}
.preview img{
width:100%;
max-height:120px;
object-fit:cover;
border-radius:8px;
margin-top:10px;
}
.bloc a{
display:inline-block;
margin-top:8px;
}
.dropdown{
position:relative;
display:inline-block;
}

.dropdown-menu{
display:none;
position:absolute;
background:white;
min-width:160px;
border-radius:8px;
box-shadow:0 4px 10px rgba(0,0,0,0.2);
margin-top:8px;
}

.dropdown-menu a{
display:block;
padding:10px;
text-decoration:none;
color:black;
}

.dropdown-menu a:hover{
background:#f2f2f2;
}

.dropdown:hover .dropdown-menu{
display:block;
}
/* Premiere partie du code index html */

/* animation SVG */

.svg-animation circle{
fill:#d4a373;
animation: couleur 3s infinite alternate;
}

/* menu ressources */

.ressource-menu{
position:relative;
display:inline-block;
margin-top:15px;
}

.ressource-titre{
background-color:#d4a373;
color:white;
padding:10px 18px;
border-radius:8px;
cursor:pointer;
}

.ressource-liens{
display:none;
position:absolute;
background:white;
margin-top:10px;
border-radius:8px;
box-shadow:0 4px 10px rgba(0,0,0,0.2);
}

.ressource-liens a{
display:block;
padding:10px 15px;
text-decoration:none;
color:black;
}

.ressource-liens a:hover{
background:#f2f2f2;
}

.ressource-menu:hover .ressource-liens{
display:block;
}


/* animation bienvenue */

.bienvenue-animation{
animation: bouger 3s infinite alternate;
}

@keyframes bouger{

from{
transform:translateX(0px);
}

to{
transform:translateX(20px);
}

}
/* PAGE VISITE & CONTACT */

.page-contact{
    padding:40px;
}

.titre-page{
    text-align:center;
    margin-bottom:40px;
}

.contact-grid{
    display:flex;
    gap:25px;
    margin-bottom:35px;
}

.carte-contact{
    background-color:#2b4c7e;
    padding:25px;
    border-radius:14px;
    flex:1;
}

.ressources-card{
    background-color:#2b4c7e;
    padding:25px;
    border-radius:14px;
    margin-bottom:35px;
}

.ressource-menu{
    position:relative;
    display:inline-block;
    margin-top:15px;
}

.ressource-titre{
    background-color:#d4a373;
    color:white;
    padding:10px 18px;
    border-radius:8px;
    cursor:pointer;
    display:inline-block;
}

.ressource-liens{
   .ressource-liens{
display:none;
position:absolute;
background:white;
top:100%;
left:0;
border-radius:8px;
box-shadow:0 4px 10px rgba(0,0,0,0.2);
min-width:280px;
}
}

.ressource-liens a{
    display:block;
    padding:12px 15px;
    text-decoration:none;
    color:black;
}

.ressource-liens a:hover{
    background:#f2f2f2;
}

.ressource-menu:hover .ressource-liens{
    display:block;
}

.bienvenue-card{
    background-color:#2b4c7e;
    padding:25px;
    border-radius:14px;
}

.texte-bienvenue{
    display:inline-block;
    margin:0;
    animation: glisser 2s ease-in-out infinite alternate;
}


@media (max-width:768px){
    .contact-grid{
        flex-direction:column;
    }

    .ressource-liens{
        min-width:220px;
    }
}
/* slogan accueil */
.slogan{
    font-size:20px;
    font-weight:bold;
    margin-bottom:12px;
}

/* image map accueil */
.hero-image img{
    width:100%;
    height:auto;
    display:block;
    border-radius:12px;
}

/* aperçu au survol */
.preview{
    display:none;
    margin-top:10px;
}
